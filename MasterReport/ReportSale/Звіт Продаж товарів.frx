using FastReport.Utils;

namespace FastReport
{
         
  
  public class ReportScript
  {       
    public string PercentIncome(decimal sumSale, decimal sumIncome)
    {
      if(sumSale == 0)
        return &quot;&quot;;
      
      return Math.Round(sumIncome/sumSale*100, 2) + &quot;%&quot;;
    }
  }
}

             </ScriptText>
