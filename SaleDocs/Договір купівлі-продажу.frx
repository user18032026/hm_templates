      <RichObject Name="Rich1" Left="9.45" Top="9.45" Width="695.52" Height="576.45" CanGrow="true" CanShrink="true" GrowToBottom="true" Text="{\rtf1\ansi\ansicpg1251\deff0\nouicompat\deflang1049{\fonttbl{\f0\fnil\fcharset204 Times New Roman;}{\f1\fnil\fcharset0 Times New Roman;}{\f2\froman\fprq2\fcharset204 Times New Roman;}{\f3\froman\fprq2\fcharset0 Times New Roman;}{\f4\fmodern\fprq1\fcharset204 Courier New;}}&#13;&#10;{\colortbl ;\red0\green0\blue0;\red255\green255\blue255;\red255\green0\blue0;}&#13;&#10;{\*\generator Riched20 10.0.22000}\viewkind4\uc1 &#13;&#10;\pard\hyphpar0\widctlpar\qc\cf1\b\f0\fs20\lang1058 1. \'cf\'d0\'c5\'c4\'cc\'c5\'d2 \'c4\'ce\'c3\'ce\'c2\'ce\'d0\'d3\b0\par&#13;&#10;&#13;&#10;\pard\hyphpar0\widctlpar\qj 1.1. \'cf\'f0\'ee\'e4\'e0\'e2\'e5\'f6\'fc \'e7\'ee\'e1\'ee\'e2\rquote\'ff\'e7\'f3\'ba\'f2\'fc\'f1\'ff \'ef\'e5\'f0\'e5\'e4\'e0\'f2\'e8 \'d2\'ee\'e2\'e0\'f0 \'f3 \'e2\'eb\'e0\'f1\'ed\'b3\'f1\'f2\'fc \'cf\'ee\'ea\'f3\'ef\'f6\'e5\'e2\'b3, \'e0 \'cf\'ee\'ea\'f3\'ef\'e5\'f6\'fc \'e7\'ee\'e1\'ee\'e2\rquote\'ff\'e7\'f3\'ba\'f2\'fc\'f1\'ff \'ef\'f0\'e8\'e9\'ec\'e0\'f2\'e8 \'d2\'ee\'e2\'e0\'f0 \'b3 \'f1\'ef\'eb\'e0\'f7\'f3\'e2\'e0\'f2\'e8 \'e9\'ee\'e3\'ee \'e2\'e0\'f0\'f2\'b3\'f1\'f2\'fc \'ed\'e0 \'f3\'ec\'ee\'e2\'e0\'f5 \'e4\'e0\'ed\'ee\'e3\'ee \'c4\'ee\'e3\'ee\'e2\'ee\'f0\'f3. \par&#13;&#10;1.2. \'d2\'ee\'e2\'e0\'f0 \'e7\'e0 \'c4\'ee\'e3\'ee\'e2\'ee\'f0\'ee\'ec \'ef\'e5\'f0\'e5\'e4\'e0\'ba\'f2\'fc\'f1\'ff \'ef\'e0\'f0\'f2\'b3\'ff\'ec\'e8 \'e2\'b3\'e4\'ef\'ee\'e2\'b3\'e4\'ed\'ee \'e4\'ee \'c7\'e0\'ec\'ee\'e2\'eb\'e5\'ed\'ed\'ff \'cf\'ee\'ea\'f3\'ef\'f6\'ff.\par&#13;&#10;1.3.\~\'cd\'e0\'e9\'ec\'e5\'ed\'f3\'e2\'e0\'ed\'ed\'ff, \'e0\'f1\'ee\'f0\'f2\'e8\'ec\'e5\'ed\'f2, \'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'ed\'b3\'f1\'f2\'fc \'d2\'ee\'e2\'e0\'f0\'f3 \'f2\'e0 \'e9\'ee\'e3\'ee \'e2\'e0\'f0\'f2\'b3\'f1\'f2\'fc, \'e2\'ea\'e0\'e7\'f3\'ba\'f2\'fc\'f1\'ff \'f3 \'e2\'e8\'e4\'e0\'f2\'ea\'ee\'e2\'b3\'e9 \'ed\'e0\'ea\'eb\'e0\'e4\'ed\'b3\'e9, \'ff\cf0\highlight2\'ea\'e0 \'ba \'ed\'e5\'e2\'b3\'e4\rquote\'ba\'ec\'ed\'ee\'fe \'f7\'e0\'f1\'f2\'e8\'ed\'ee\'fe \'f6\'fc\'ee\'e3\'ee \'c4\'ee\'e3\'ee\'e2\'ee\'f0\'f3\highlight0  \par&#13;&#10;1.4.\~\'cf\'f0\'ee\'e4\'e0\'e2\'e5\'f6\'fc \'e3\'e0\'f0\'e0\'ed\'f2\'f3\'ba \'cf\'ee\'ea\'f3\'ef\'f6\'fe, \'f9\'ee \'d2\'ee\'e2\'e0\'f0, \'ff\'ea\'e8\'e9 \'ef\'e5\'f0\'e5\'e4\'e0\'ba\'f2\'fc\'f1\'ff \'e7\'e0 \'f6\'e8\'ec \'c4\'ee\'e3\'ee\'e2\'ee\'f0\'ee\'ec, \'ff\'ea\'b3\'f1\'ed\'e8\'e9 \'f2\'e0 \'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'ed\'e8\'e9, \'ed\'b3\'ea\'ee\'ec\'f3 \'ed\'e5 \'ef\'f0\'ee\'e4\'e0\'ed\'e8\'e9, \'ed\'e5 \'e7\'e0\'f1\'f2\'e0\'e2\'eb\'e5\'ed\'e8\'e9, \'e2 \'f1\'ef\'ee\'f0\'b3 \'f2\'e0 \'ef\'b3\'e4 \'e7\'e0\'e1\'ee\'f0\'ee\'ed\'ee\'fe (\'e0\'f0\'e5\'f8\'f2\'ee\'ec, \'ef\'ee\'e4\'e0\'f2\'ea\'ee\'e2\'ee\'fe \'e7\'e0\'f1\'f2\'e0\'e2\'ee\'fe \'f2\'ee\'f9\'ee) \'ed\'e5 \'ef\'e5\'f0\'e5\'e1\'f3\'e2\'e0\'ba, \'e6\'ee\'e4\'ed\'b3 \'ef\'f0\'e0\'e2\'e0 \'ed\'e0 \'d2\'ee\'e2\'e0\'f0 \'b3\'ed\'f8\'e8\'ec \'ee\'f1\'ee\'e1\'e0\'ec \'ed\'e5 \'ef\'e5\'f0\'e5\'e4\'e0\'ed\'b3.\lang1049\par&#13;&#10;&#13;&#10;\pard\nowidctlpar\hyphpar0\qj\cf1 1.5. \cf0\lang1058\'cf\'f0\'e0\'e2\'ee \'e2\'eb\'e0\'f1\'ed\'ee\'f1\'f2\'b3 \'ed\'e0 \'d2\'ee\'e2\'e0\'f0 \'f2\'e0 \'f0\'e8\'e7\'e8\'ea \'e2\'e8\'ef\'e0\'e4\'ea\'ee\'e2\'ee\'e3\'ee \'e7\'ed\'e8\'f9\'e5\'ed\'ed\'ff \'e0\'e1\'ee \'ef\'ee\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'ed\'ff \'d2\'ee\'e2\'e0\'f0\'f3  \'ef\'e5\'f0\'e5\'f5\'ee\'e4\'e8\'f2\'fc \'e2\'b3\'e4 \'cf\'f0\'ee\'e4\'e0\'e2\'f6\'ff \'e4\'ee \'cf\'ee\'ea\'f3\'ef\'f6\'ff, \'e7 \'ec\'ee\'ec\'e5\'ed\'f2\'f3 \'ef\'e5\'f0\'e5\'e4\'e0\'f7\'b3 \'d2\'ee\'e2\'e0\'f0\'f3 \'f2\'e0 \'ef\'b3\'e4\'ef\'e8\'f1\'e0\'ed\'ed\'ff \'e2\'e8\'e4\'e0\'f2\'ea\'ee\'e2\'ee\'bf \'ed\'e0\'ea\'eb\'e0\'e4\'ed\'ee\'bf.\par&#13;&#10;&#13;&#10;\pard\hyphpar0\widctlpar\qj\par&#13;&#10;&#13;&#10;\pard\hyphpar0\widctlpar\qc\cf1\b 2. \'d3\'cc\'ce\'c2\'c8 \'ce\'cf\'cb\'c0\'d2\'c8 \b0\par&#13;&#10;&#13;&#10;\pard\hyphpar0\widctlpar\qj 2.1. \'d2\'ee\'e2\'e0