      <RichObject Name="Rich1" Left="9.45" Top="9.45" Width="695.52" Height="576.45" CanShrink="true" GrowToBottom="true" Text="{\rtf1\ansi\ansicpg1251\deff0\nouicompat\deflang1049{\fonttbl{\f0\fnil\fcharset0 Times New Roman;}{\f1\fnil\fcharset204 Times New Roman;}{\f2\fnil Times New Roman;}}&#13;&#10;{\*\generator Riched20 10.0.22000}\viewkind4\uc1 &#13;&#10;\pard\kerning1\b\f0\fs18\lang1033 1. \b0 [CompanyName]\f1\lang1058  \'e7\'ee\'e1\'ee\'e2\f0\lang1033 '\f1\lang1058\'ff\'e7\'f3\'ba\'f2\'fc\'f1\'ff\f0\lang1033  \f1\lang1058\'e7\'e4\'b3\'e9\'f1\'ed\'fe\'e2\'e0\'f2\'e8\f0\lang1033  \f1\lang1058\'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'f3\f0\lang1033  \f1\lang1058\'ef\'b3\'e4\'f2\'f0\'e8\'ec\'ea\'f3\f0\lang1033  \f1\lang1058\'c2\'e8\'f0\'ee\'e1\'b3\'e2\f0\lang1033 , \f1\lang1058\'ef\'ee\'f1\'f2\'e0\'e2\'eb\'e5\'ed\'e8\'f5\f0\lang1033  \f1\lang1058\'c7\'e0\'ec\'ee\'e2\'ed\'e8\'ea\'ee\'e2\'b3\f0\lang1033 , \f1\lang1058\'ed\'e5\'f1\'ef\'f0\'e0\'e2\'ed\'b3\'f1\'f2\'fc\f0\lang1033 , \f1\lang1058\'ff\'ea\'e8\'f5\f0\lang1033  \f1\lang1058\'e2\'b3\'e4\'e1\'f3\'eb\'e0\'f1\'ff\f0\lang1033  \f1\lang1058\'e7\f0\lang1033  \f1\lang1058\'e2\'e8\'ed\'e8\f0\lang1033  \f1\lang1058\'e2\'e8\'f0\'ee\'e1\'ed\'e8\'ea\'e0\f0\lang1033 , \f1\lang1058\'ee\'ea\'f0\'b3\'ec\f0\lang1033  \f1\lang1058\'e2\'e8\'ef\'e0\'e4\'ea\'b3\'e2\f0\lang1033  \f1\lang1058\'e2\'e7\'e0\'ba\'ec\'ed\'ee\'bf\f0\lang1033  \f1\lang1058\'e4\'ee\'ec\'ee\'e2\'eb\'e5\'ed\'ee\'f1\'f2\'b3\f0\lang1033  \f1\lang1058\'ef\'f0\'ee\f0\lang1033  \f1\lang1058\'ef\'ee\'f1\'f2\'e0\'f7\'e0\'ed\'ed\'ff\f0\lang1033  \f1\lang1058\'ef\'f0\'ee\'e4\'f3\'ea\'f6\'b3\'bf\f0\lang1033  \f1\lang1058\'e1\'e5\'e7\f0\lang1033  \f1\lang1058\'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'ee\'bf\f0\lang1033  \f1\lang1058\'ef\'b3\'e4\'f2\'f0\'e8\'ec\'ea\'e8\f0\lang1033 .\par&#13;&#10;\par&#13;&#10;\b 2. \f1\lang1058\'cf\'b3\'e4\'f1\'f2\'e0\'e2\'ee\'fe \'e4\'eb\'ff \'e7\'e4\'b3\'e9\'f1\'ed\'e5\'ed\'ed\'ff \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'ee\'bf \'ef\'b3\'e4\'f2\'f0\'e8\'ec\'ea\'e8 \'ba \'ed\'e0\'f1\'f2\'f3\'ef\'ed\'b3 \'f3\'ec\'ee\'e2\'e8: \par&#13;&#10;\b0 - \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'e8\'e9 \'f0\'e5\'ec\'ee\'ed\'f2 \'ef\'f0\'ee\'e2\'ee\'e4\'e8\'f2\'fc\'f1\'ff \'f2\'b3\'eb\'fc\'ea\'e8 \'e2 \'f3\'ef\'ee\'e2\'ed\'ee\'e2\'e0\'e6\'e5\'ed\'ee\'ec\'f3 \'f1\'e5\'f0\'e2\'b3\'f1\'ed\'ee\'ec\'f3 \'f6\'e5\'ed\'f2\'f0\'b3 (\'d3\'d1\'d6) \'ef\'f0\'ee\'f2\'ff\'e3\'ee\'ec \'f2\'e5\'f0\'ec\'b3\'ed\'f3 \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'bf, \'e7\'e0\'e7\'ed\'e0\'f7\'e5\'ed\'ee\'e3\'ee \'e2 \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'ee\'ec\'f3 \'b3 \'e2\'b3\'e4\'f0\'e8\'e2\'ed\'e8\'f5 \'f2\'e0\'eb\'ee\'ed\'e0\'f5; \par&#13;&#10;- \'ef\'f0\'e8 \'f3\'f1\'f3\'ed\'e5\'ed\'b3 \'ed\'e5\'e4\'ee\'eb\'b3\'ea\'b3\'e2 \'f8\'eb\'ff\'f5\'ee\'ec \'e7\'e0\'ec\'b3\'ed\'e8 \'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'f3\'fe\'f7\'e8\'f5 \'e0\'e1\'ee \'f1\'ea\'eb\'e0\'e4\'ee\'e2\'e8\'f5 \'f7\'e0\'f1\'f2\'e8\'ed \'e2\'e8\'f0\'ee\'e1\'f3, \'ed\'e0 \'ff\'ea\'b3 \'e2\'f1\'f2\'e0\'ed\'ee\'e2\'eb\'e5\'ed\'ee \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'b3 \'f2\'e5\'f0\'ec\'b3\'ed\'e8, \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'e8\'e9 \'f2\'e5\'f0\'ec\'b3\'ed \'ed\'e0 \'ed\'ee\'e2\'b3 \'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'f3\'fe\'f7\'b3 \'e0\'e1\'ee \'f1\'ea\'eb\'e0\'e4\'ee\'e2\'b3 \'f7\'e0\'f1\'f2\'e8\'ed\'e8 \'e2\'e8\'f0\'ee\'e1\'f3 \'ee\'e1\'f7\'e8\'f1\'eb\'fe\'ba\'f2\'fc\'f1\'ff \'e2\'b3\'e4 \'e4\'ed\'ff \'e2\'e8\'e4\'e0\'f7\'b3 \'f1\'ef\'ee\'e6\'e8\'e2\'e0\'f7\'e5\'e2\'b3 \'e2\'e8\'f0\'ee\'e1\'f3 \'ef\'b3\'f1\'eb\'ff \'f0\'e5\'ec\'ee\'ed\'f2\'f3 \'b3 \'f1\'ea\'eb\'e0\'e4\'e0\'ba \'ee\'e4\'e8\'ed \'ec\'b3\'f1\'ff\'f6\'fc; \par&#13;&#10;- \'ed\'e5\'f1\'ef\'f0\'e0\'e2\'ed\'b3 \'e2\'f3\'e7\'eb\'e8 \'e2\'e8\'f0\'ee\'e1\'f3 \'e2 \'ef\'e5\'f0\'b3\'ee\'e4 \'e4\'b3\'bf \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'e8\'f5 \'e7\'ee\'e1\'ee\'e2\rquote\'ff\'e7\'e0\'ed\'fc \'f0\'e5\'ec\'ee\'ed\'f2\'f3\'fe\'f2\'fc\'f1\'ff \'e7\'e0 \'f0\'e0\'f5\'f3\'ed\'ee\'ea \'d3\'d1\'d6 \'e0\'e1\'ee \'e7\'e0\'ec\'b3\'ed\'fe\'fe\'f2\'fc\'f1\'ff \'ef\'f0\'e0\'f6\'e5\'e7\'e4\'e0\'f2\'ed\'e8\'ec\'e8. \'d0\'b3\'f8\'e5\'ed\'ed\'ff \'ef\'f0\'ee \'e4\'ee\'f6\'b3\'eb\'fc\'ed\'b3\'f1\'f2\'fc \'f0\'e5\'ec\'ee\'ed\'f2\'f3 \'e0\'e1\'ee \'e7\'e0\'ec\'b3\'ed\'e8 \'ef\'f0\'e8\'e9\'ec\'e0\'ba \'f4\'e0\'f5\'b3\'e2\'f6\'b3 \'d3\'d1\'d6. \par&#13;&#10;- \'ed\'e5\'f1\'ef\'f0\'e0\'e2\'ed\'b3 \'e2\'f3\'e7\'eb\'e8 \'e7\'e0\'ec\'b3\'ed\'e5\'ed\'b3 \'e2 \'ef\'e5\'f0\'b3\'ee\'e4 \'e4\'b3\'bf \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'e8\'f5 \'e7\'ee\'e1\'ee\'e2'\'ff\'e7\'e0\'ed\'fc, \'ef\'e5\'f0\'e5\'f5\'ee\'e4\'e8\'f2\'fc \'f3 \'e2\'eb\'e0\'f1\'ed\'b3\'f1\'f2\'fc \'d3\'d1\'d6; \par&#13;&#10;- \'c2\'e8\'f0\'b3\'e1 \'ef\'f0\'e8\'e9\'ec\'e0\'ba\'f2\'fc\'f1\'ff \'e2 \'f0\'e5\'ec\'ee\'ed\'f2 \'f2\'b3\'eb\'fc\'ea\'e8 \'e2 \'ee\'f0\'e8\'e3\'b3\'ed\'e0\'eb\'fc\'ed\'b3\'e9 \'f3\'ef\'e0\'ea\'ee\'e2\'f6\'b3 \'f2\'e0 \'f3\'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'ee\'e2\'e0\'ed\'e8\'e9 \'e7\'e3\'b3\'e4\'ed\'ee \'e7 \'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'ee\'ec \'ef\'ee\'f1\'f2\'e0\'e2\'ea\'e8, \'e7\'e0\'e7\'ed\'e0\'f7\'e5\'ed\'ee\'e3\'ee \'e2 \'b3\'ed\'f1\'f2\'f0\'f3\'ea\'f6\'b3\'bf \'ef\'ee \'e5\'ea\'f1\'ef\'eb\'f3\'e0\'f2\'e0\'f6\'b3\'bf; \par&#13;&#10;\b 3. \'c2\'e8\'f0\'ee\'e1\'e8 \'e7\'ed\'b3\'ec\'e0\'fe\'f2\'fc\'f1\'ff \'e7 \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'bf \'f3 \'e2\'e8\'ef\'e0\'e4\'ea\'e0\'f5: \b0\par&#13;&#10;- \'e2\'e8\'f0\'ee\'e1\'ed\'e8\'ea \'ef\'f0\'e8\'ef\'e8\'ed\'ff\'ba \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'f3 \'ef\'b3\'e4\'f2\'f0\'e8\'ec\'ea\'f3 \'c2\'e8\'f0\'ee\'e1\'f3, \'ef\'f0\'ee \'f9\'ee \'f1\'e2\'b3\'e4\'f7\'e8\'f2\'fc \'ee\'f4\'b3\'f6\'b3\'e9\'ed\'e5 \'ef\'ee\'e2\'b3\'e4\'ee\'ec\'eb\'e5\'ed\'ed\'ff; \par&#13;&#10;- \'e2\'e8\'ff\'e2\'eb\'e5\'ed\'ed\'ff \'ef\'ee\'f0\'f3\'f8\'e5\'ed\'fc \'ef\'f0\'e0\'e2\'e8\'eb \'f3\'f1\'f2\'e0\'ed\'ee\'e2\'ea\'e8 \'b3 \'e5\'ea\'f1\'ef\'eb\'f3\'e0\'f2\'e0\'f6\'b3\'bf \'c2\'e8\'f0\'ee\'e1\'f3; \par&#13;&#10;- \'e2\'e8\'ff\'e2\'eb\'e5\'ed\'ed\'ff \'f1\'eb\'b3\'e4\'b3\'e2 \'f0\'e5\'ec\'ee\'ed\'f2\'f3 \'e2 \'ed\'e5 \'f3\'ef\'ee\'e2\'ed\'ee\'e2\'e0\'e6\'e5\'ed\'ee\'ec\'f3 \'f1\'e5\'f0\'e2\'b3\'f1\'ed\'ee\'ec\'f3 \'f6\'e5\'ed\'f2\'f0\'b3 \'e0\'e1\'ee \'b3\'ed\'f8\'ee\'e3\'ee \'ed\'e5\'f1\'e0\'ed\'ea\'f6\'b3\'ee\'ed\'ee\'e2\'e0\'ed\'ee\'e3\'ee \'e2\'f2\'f0\'f3\'f7\'e0\'ed\'ed\'ff; \par&#13;&#10;- \'e7\'e0 \'e2\'b3\'e4\'f1\'f3\'f2\'ed\'ee\'f1\'f2\'b3 \'ed\'e0 \'c2\'e8\'f0\'ee\'e1\'b3 \'e7\'e0\'e2\'ee\'e4\'f1\'fc\'ea\'e8\'f5 \'e4\'e0\'ed\'e8\'f5 \f2\emdash  \f1\'f1\'e5\'f0\'b3\'e9\'ed\'ee\'e3\'ee \'ed\'ee\'ec\'e5\'f0\'e0 \'b3 \'ed\'ee\'ec\'e5\'f0\'e0 \'ef\'e0\'f0\'f2\'b3\'bf, \'e7\'e0\'e2\'ee\'e4\'f1\'fc\'ea\'e8\'f5 \'ef\'eb\'ee\'ec\'e1, \'e0 \'f2\'e0\'ea\'ee\'e6 \'ef\'f0\'e8 \'ef\'ee\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'ed\'ff\'f5 \'ed\'e0\'ef\'e8\'f1\'b3\'e2, \'f9\'ee \'f0\'ee\'e1\'eb\'ff\'f2\'fc \'ed\'e5\'ec\'ee\'e6\'eb\'e8\'e2\'ee\'fe \'bf\'f5 \'f0\'ee\'e7\'f8\'e8\'f4\'f0\'ee\'e2\'ea\'f3; \par&#13;&#10;- \'e7\'e0 \'ed\'e0\'ff\'e2\'ed\'ee\'f1\'f2\'b3 \'ec\'e5\'f5\'e0\'ed\'b3\'f7\'ed\'e8\'f5 \'ef\'ee\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'fc, \'f2\'e0\'ea\'e8\'f5 \'ff\'ea \'f2\'f0\'b3\'f9\'e8\'ed\'e8, \'e3\'eb\'e8\'e1\'ee\'ea\'b3 \'ef\'ee\'e4\'f0\'ff\'ef\'e8\'ed\'e8, \'e2\'b3\'e4\'f1\'f3\'f2\'ed\'ee\'f1\'f2\'b3 \'f1\'ef\'ee\'eb\'f3\'f7\'ed\'e8\'f5 \'e3\'e2\'e8\'ed\'f2\'b3\'e2, \'f7\'e0\'f1\'f2\'e8\'ed \'e2 \'e2\'f3\'e7\'eb\'b3\'e2 \'c2\'e8\'f0\'ee\'e1\'f3, \'ec\'e5\'f5\'e0\'ed\'b3\'f7\'ed\'e5 \'f0\'ee\'e7\rquote\'ba\'e4\'ed\'e0\'ed\'ed\'ff \'e5\'eb\'e5\'ea\'f2\'f0\'e8\'f7\'ed\'e8\'f5 \'e7\rquote\'ba\'e4\'ed\'e0\'ed\'fc; \par&#13;&#10;- \'ed\'e5\'f1\'e0\'ed\'ea\'f6\'b3\'ee\'ed\'ee\'e2\'e0\'ed\'ee\'bf \'ec\'ee\'e4\'e8\'f4\'b3\'ea\'e0\'f6\'b3\'bf \'e2\'e8\'f0\'ee\'e1\'f3 (\'ef\'e5\'f0\'e5\'ef\'e0\'fe\'e2\'e0\'ed\'ed\'ff, \'e7\'e0\'ec\'b3\'ed\'e0 \'ec\'ee\'e4\'f3\'eb\'b3\'e2); \par&#13;&#10;- \'f4\'b3\'e7\'e8\'f7\'ed\'ee\'e3\'ee \'ef\'ee\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'ed\'ff\'f5 \'e5\'eb\'e5\'ea\'f2\'f0\'ee\'ed\'ed\'ee\'e3\'ee \'ec\'ee\'e4\'f3\'eb\'ff \'c2\'e8\'f0\'ee\'e1\'f3; \par&#13;&#10;- \'f0\'ee\'e7\'e3\'ee\'ed \'ef\'f0\'ee\'f6\'e5\'f1\'ee\'f0\'b3\'e2, \'e2\'b3\'e4\'e5\'ee-\'ea\'e0\'f0\'f2 \'f2\'e0 \'b3\'ed\'f8\'e8\'f5 \'e2\'e8\'f0\'ee\'e1\'b3\'e2; \par&#13;&#10;- \'e7\'e0 \'ed\'e0\'ff\'e2\'ed\'ee\'f1\'f2\'b3 \'ed\'e0 \'c2\'e8\'f0\'ee\'e1\'b3 \'f1\'f2\'ee\'f0\'ee\'ed\'ed\'b3\'f5 \'ed\'e0\'ef\'e8\'f1\'b3\'e2, \'ed\'e0\'ea\'eb\'e5\'e9\'ee\'ea, \'ea\'f0\'b3\'ef\'e8\'eb\'fc\'ed\'e8\'f5 \'f0\'e0\'ec\'ee\'ea \'b3 \'b3\'ed\'f8\'e8\'f5 \'e4\'ee\'ef\'ee\'e2\'ed\'e5\'ed\'fc; \par&#13;&#10;- \'ef\'f0\'e8 \'e2\'e8\'ea\'ee\'f0\'e8\'f1\'f2\'e0\'ed\'ed\'b3 \'ed\'e5\'eb\'b3\'f6\'e5\'ed\'e7\'b3\'e9\'ed\'e8\'f5 \'e0\'e1\'ee \'ef\'ee\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'e8\'f5 \'e4\'e8\'f1\'ea\'b3\'e2 \'ee\'ef\'f2\'e8\'f7\'ed\'e8\'f5 \'ef\'f0\'e8\'e2\'ee\'e4\'e0\'f5; \par&#13;&#10;- \'ef\'f0\'e8 \'ed\'e5\'e4\'ee\'f2\'f0\'e8\'ec\'e0\'ed\'ed\'b3 \'ee\'f0\'e8\'e3\'b3\'ed\'e0\'eb\'fc\'ed\'ee\'bf \'ea\'ee\'ec\'ef\'eb\'e5\'ea\'f2\'ed\'ee\'f1\'f2\'b3 \'c2\'e8\'f0\'ee\'e1\'f3; \par&#13;&#10;- \'f3\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'ed\'ff \'e2\'e8\'ea\'eb\'e8\'ea\'e0\'ed\'e8\'e9 \'ef\'ee\'ef\'e0\'e4\'e0\'ed\'ed\'ff\'ec \'e2\'f1\'e5\'f0\'e5\'e4\'e8\'ed\'f3 \'e2\'e8\'f0\'ee\'e1\'f3 \'f1\'f2\'ee\'f0\'ee\'ed\'ed\'b3\'f5 \'ef\'f0\'e5\'e4\'ec\'e5\'f2\'b3\'e2, \'f0\'b3\'e4\'e8\'ed\'e8, \'ea\'ee\'ec\'e0\'f5, \'ed\'e0\'ff\'e2\'ed\'ee\'f1\'f2\'b3 \'e7\'e0\'ef\'e8\'eb\'e5\'ed\'ed\'ff \'b3 \'f2. \'e4.; \par&#13;&#10;- \'f3\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'ed\'ff, \'f9\'ee \'e2\'e8\'ea\'eb\'e8\'ea\'e0\'ed\'b3 \'ed\'e5\'e2\'b3\'e4\'ef\'ee\'e2\'b3\'e4\'ed\'b3\'f1\'f2\'fe \'ef\'e0\'f0\'e0\'ec\'e5\'f2\'f0\'b3\'e2 \'e6\'e8\'e2\'e8\'eb\'fc\'ed\'e8\'f5, \'f2\'e5\'eb\'e5\'ea\'ee\'ec\'f3\'ed\'b3\'ea\'e0\'f6\'b3\'e9\'ed\'e8\'f5, \'ea\'e0\'e1\'e5\'eb\'fc\'ed\'e8\'f5 \'ec\'e5\'f0\'e5\'e6 \'e4\'e5\'f0\'e6\'e0\'e2\'ed\'e8\'ec \'f1\'f2\'e0\'ed\'e4\'e0\'f0\'f2\'e0\'ec, \'b3\'ed\'f8\'e8\'ec\'e8 \'ef\'ee\'e4\'b3\'e1\'ed\'e8\'ec\'e8 \'e7\'ee\'e2\'ed\'b3\'f8\'ed\'b3\'ec\'e8 \'f4\'e0\'ea\'f2\'ee\'f0\'e0\'ec\'e8; \par&#13;&#10;- \'f3\'f8\'ea\'ee\'e4\'e6\'e5\'ed\'ed\'ff, \'f9\'ee \'e2\'e8\'ea\'eb\'e8\'ea\'e0\'ed\'b3 \'e2\'e8\'ea\'ee\'f0\'e8\'f1\'f2\'e0\'ed\'ed\'ff\'ec \'ed\'e5\'f1\'f2\'e0\'ed\'e4\'e0\'f0\'f2\'ed\'e8\'f5 \'ec\'e0\'f2\'e5\'f0\'b3\'e0\'eb\'b3\'e2, \'e0\'e4\'e0\'ef\'f2\'e5\'f0\'b3\'e2, \'e1\'eb\'ee\'ea\'b3\'e2 \'e6\'e8\'e2\'eb\'e5\'ed\'ed\'ff, \'e7\'e0\'ef\'f7\'e0\'f1\'f2\'e8\'ed \'b3 \'f2. \'e4. \par&#13;&#10;\b\'c3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'b3 \'e7\'ee\'e1\'ee\'e2\rquote\'ff\'e7\'e0\'ed\'ed\'ff \'ed\'e5 \'f0\'ee\'e7\'ef\'ee\'e2\'f1\'fe\'e4\'e6\'f3\'fe\'f2\'fc\'f1\'ff \'ed\'e0: \par&#13;&#10;\b0 - \'e4\'f0\'f3\'ea\'f3\'fe\'f7\'b3 \'e3\'ee\'eb\'ee\'e2\'ea\'e8 \'e4\'eb\'ff \'ef\'f0\'e8\'ed\'f2\'e5\'f0\'b3\'e2; - \'ea\'e0\'f0\'f2\'f0\'e8\'e4\'e6\'b3 \'e4\'eb\'ff \'ec\'e0\'f2\'f0\'e8\'f7\'ed\'e8\'f5 \'ef\'f0\'e8\'ed\'f2\'e5\'f0\'b3\'e2; \par&#13;&#10;- RS(232, 422, 485)/LPT/Ethernet/PS2/USB \par&#13;&#10;- \'ef\'ee\'f0\'f2\'e8; \par&#13;&#10;- \'ef\'f0\'ee\'e3\'f0\'e0\'ec\'ed\'e5 \'e7\'e0\'e1\'e5\'e7\'ef\'e5\'f7\'e5\'ed\'ed\'ff; \par&#13;&#10;- \'e7\'ee\'e2\'ed\'b3\'f8\'ed\'b3 \'e1\'eb\'ee\'ea\'e8 \'e6\'e8\'e2\'eb\'e5\'ed\'ed\'ff, \'e0\'ea\'f3\'ec\'f3\'eb\'ff\'f2\'ee\'f0\'ed\'b3 \'b3 \'e7\'e2\'e8\'f7\'e0\'e9\'ed\'b3 \'e1\'e0\'f2\'e0\'f0\'e5\'bf, \'f0\'e5\'ec\'ed\'b3, \'e7\'e0\'f5\'e8\'f1\'ed\'b3 \'e5\'ea\'f0\'e0\'ed\'e8, \'b3\'ed\'f2\'e5\'f0\'f4\'e5\'e9\'f1\'ed\'b3 \'ea\'e0\'e1\'e5\'eb\'b3, \'ea\'e0\'e1\'e5\'eb\'b3 \'e6\'e8\'e2\'eb\'e5\'ed\'ed\'ff \'b3 \'b3\'ed\'f8\'b3 \'e4\'e5\'f2\'e0\'eb\'b3 \'f9\'ee \'ec\'e0\'fe\'f2\'fc \'ee\'e1\'ec\'e5\'e6\'e5\'ed\'e8\'e9 \'f2\'e5\'f0\'ec\'b3\'ed \'e5\'ea\'f1\'ef\'eb\'f3\'e0\'f2\'e0\'f6\'b3\'bf. \par&#13;&#10;\par&#13;&#10;&#13;&#10;\pard\qc\b\'c1\'e5\'e7 \'ef\'b3\'e4\'ef\'e8\'f1\'f3 \'ef\'ee\'ea\'f3\'ef\'f6\'ff \'e3\'e0\'f0\'e0\'ed\'f2\'b3\'e9\'ed\'e8\'e9 \'f2\'e0\'eb\'ee\'ed \'e2\'e2\'e0\'e6\'e0\'ba\'f2\'fc\'f1\'ff \'ed\'e5 \'e4\'b3\'e9\'f1\'ed\'e8\'ec\kerning0\lang1049\par&#13;&#10;}&#13;&#10;"/>
