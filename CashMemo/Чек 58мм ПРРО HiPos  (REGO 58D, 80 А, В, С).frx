<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="06/20/2009 22:40:42" ReportInfo.Modified="03/17/2026 15:24:04" ReportInfo.CreatorVersion="2020.1.28.0">
  <ScriptText>using System;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
using System.Windows.Forms;
using System.Drawing;
using System.Data;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;

namespace FastReport
{
  public class ReportScript
  {
    string nl = &quot;\r\n&quot;;
  }
}</ScriptText>
  <Dictionary>
    <BusinessObjectDataSource Name="items" ReferenceName="items" DataType="null" Enabled="true">
      <Column Name="Code" DataType="System.String"/>
      <Column Name="Barcode" DataType="System.String"/>
      <Column Name="Uktzed" DataType="System.String"/>
      <Column Name="Dkpp" DataType="System.Object"/>
      <Column Name="Name" DataType="System.String"/>
      <Column Name="UnitCode" DataType="System.String"/>
      <Column Name="UnitName" DataType="System.Object"/>
      <Column Name="Amount" DataType="System.Decimal"/>
      <Column Name="Price" DataType="System.Decimal"/>
      <Column Name="Discount" DataType="System.Decimal"/>
      <Column Name="Cost" DataType="System.Decimal"/>
      <Column Name="TaxCode" DataType="System.String"/>
      <Column Name="TaxPrc" DataType="System.Nullable`1[[System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"/>
      <Column Name="ExciseCode" DataType="System.Object"/>
      <Column Name="ExcisePrc" DataType="System.Object"/>
      <Column Name="Letters" DataType="System.String"/>
    </BusinessObjectDataSource>
    <BusinessObjectDataSource Name="payments" ReferenceName="payments" DataType="null" Enabled="true">
      <Column Name="TypeOfPayment" DataType="System.Int32"/>
      <Column Name="PayFormNm" DataType="System.String"/>
      <Column Name="PayFormCd" DataType="System.Decimal"/>
      <Column Name="Sum" DataType="System.Decimal"/>
      <Column Name="Provided" DataType="System.Int32"/>
      <Column Name="Remains" DataType="System.Decimal"/>
      <Column Name="PaymentSystem" DataType="System.String"/>
      <Column Name="TransactionCode" DataType="System.String"/>
      <Column Name="BankId" DataType="System.String"/>
      <Column Name="TerminalId" DataType="System.String"/>
      <Column Name="PaymentName" DataType="System.String"/>
      <Column Name="CardNumber" DataType="System.String"/>
      <Column Name="AuthorizationId" DataType="System.String"/>
      <Column Name="PosTransactionDate" DataType="System.Nullable`1[[System.DateTime, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"/>
      <Column Name="PosTransactionNumber" DataType="System.String"/>
      <Column Name="Commission" DataType="System.Nullable`1[[System.Decimal, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"/>
    </BusinessObjectDataSource>
    <BusinessObjectDataSource Name="taxes" ReferenceName="taxes" DataType="null" Enabled="true">
      <Column Name="Id" DataType="System.Int32"/>
      <Column Name="TaxCode" DataType="System.String"/>
      <Column Name="TaxPrc" DataType="System.Decimal"/>
      <Column Name="TaxSum" DataType="System.Decimal"/>
      <Column Name="TurnOver" DataType="System.Decimal"/>
      <Column Name="Type" DataType="System.Int32"/>
      <Column Name="Name" DataType="System.String"/>
      <Column Name="Letter" DataType="System.String"/>
      <Column Name="Sign" DataType="System.Boolean" BindableControl="CheckBox"/>
    </BusinessObjectDataSource>
    <BusinessObjectDataSource Name="excises" ReferenceName="excises" DataType="null" Enabled="true">
      <Column Name="ExciseCode" DataType="System.String"/>
      <Column Name="ExcisePrc" DataType="System.Decimal"/>
      <Column Name="ExciseSum" DataType="System.Decimal"/>
      <Column Name="TurnOver" DataType="System.Decimal"/>
      <Column Name="Type" DataType="System.Int32"/>
      <Column Name="Name" DataType="System.String"/>
      <Column Name="Letter" DataType="System.String"/>
      <Column Name="Sign" DataType="System.Boolean" BindableControl="CheckBox"/>
    </BusinessObjectDataSource>
    <Parameter Name="CompanyAddress" DataType="System.String"/>
    <Parameter Name="CompanyName" DataType="System.String"/>
    <Parameter Name="CompanyPhone" DataType="System.String"/>
    <Parameter Name="CompanyPublicPointName" DataType="System.String"/>
    <Parameter Name="CompanyInfo" DataType="System.String"/>
    <Parameter Name="CompanyInn" DataType="System.String"/>
    <Parameter Name="CompanyKPP" DataType="System.String"/>
    <Parameter Name="CompanyOGRN" DataType="System.String"/>
    <Parameter Name="CompanyBank" DataType="System.String"/>
    <Parameter Name="CompanyBik" DataType="System.String"/>
    <Parameter Name="CompanyKs" DataType="System.String"/>
    <Parameter Name="CompanyRs" DataType="System.String"/>
    <Parameter Name="DbName" DataType="System.String"/>
    <Parameter Name="ShiftId" DataType="System.Int32"/>
    <Parameter Name="Ver" DataType="System.Int32"/>
    <Parameter Name="Uid" DataType="System.String"/>
    <Parameter Name="Tin" DataType="System.String"/>
    <Parameter Name="Ipn" DataType="System.String"/>
    <Parameter Name="OrgName" DataType="System.String"/>
    <Parameter Name="PointName" DataType="System.String"/>
    <Parameter Name="PointAddr" DataType="System.String"/>
    <Parameter Name="OrderDate" DataType="System.DateTime"/>
    <Parameter Name="OrderRetNum" DataType="System.String"/>
    <Parameter Name="Sent" DataType="System.Boolean"/>
    <Parameter Name="Canceled" DataType="System.Boolean"/>
    <Parameter Name="Offline" DataType="System.Boolean"/>
    <Parameter Name="Oflsid" DataType="System.Int32"/>
    <Parameter Name="OrderNum" DataType="System.Double"/>
    <Parameter Name="OrderTaxNum" DataType="System.String"/>
    <Parameter Name="CashDeskNum" DataType="System.Double"/>
    <Parameter Name="CashRegisterNum" DataType="System.Double"/>
    <Parameter Name="RevokeLastOnlineDoc" DataType="System.Boolean"/>
    <Parameter Name="Cashier" DataType="System.String"/>
    <Parameter Name="TotalSum" DataType="System.Decimal"/>
    <Parameter Name="RoundSum" DataType="System.Decimal"/>
    <Parameter Name="NoRoundSum" DataType="System.Decimal"/>
    <Parameter Name="Discount" DataType="System.Decimal"/>
    <Parameter Name="HeaderFiscalLines" DataType="System.String"/>
    <Parameter Name="FooterFiscalLines" DataType="System.String"/>
    <Parameter Name="QrLink" DataType="System.String"/>
    <Parameter Name="DocType" DataType="System.Int32"/>
    <Total Name="TotalDiscount" Expression="[items.Discount]" Evaluator="Data1"/>
  </Dictionary>
  <ReportPage Name="Page1" PaperWidth="58" PaperHeight="0" LeftMargin="0" TopMargin="5" RightMargin="0" BottomMargin="5" Guides="0,185.22,94.5,189,201.28,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,198.45,189,198.45,198.45,198.45,198.45,198.45,179.55,179.55" Watermark.Font="Arial, 60pt" UnlimitedHeight="true" PrintOnRollPaper="true">
    <ReportTitleBand Name="ReportTitle1" Width="219.24" Height="20.79" CanGrow="true" CanShrink="true">
      <TextObject Name="Text23" Left="18.14" Width="182.92" Height="17.54" CanGrow="true" Text="[IIf(Length([OrgName])&gt;0m,[OrgName] + nl + [PointName] + nl + [PointAddr] + IIf(Length([Ipn])&gt;0m,nl + &quot;ПН &quot; + [Ipn] + nl + &quot;ІД &quot; +  [Tin],nl + &quot;ІД &quot; +  [Tin]) + nl + &quot;КАСИР: &quot; + [Cashier], &quot;КАСИР: &quot; + [Cashier])]" HorzAlign="Center" VertAlign="Center" Font="Arial, 7.5pt, style=Bold"/>
    </ReportTitleBand>
    <DataBand Name="Data1" Top="23.17" Width="219.24" Height="28.35" CanGrow="true" CanShrink="true" Guides="0,56.7,18.9,37.8" DataSource="items" KeepTogether="true" KeepDetail="true">
      <TextObject Name="Text32" Left="18.14" Top="1.89" Width="182.95" Height="17.01" CanGrow="true" CanShrink="true" Text="[Row#]. [items.Name] [IIf(Length([items.Uktzed])&gt;0m,nl + &quot;УКТЗЕД: &quot; + [items.Uktzed], &quot;&quot;)] [IIf(Length([items.Barcode])&gt;0m,nl + &quot;ШК: &quot; + [items.Barcode], &quot;&quot;)] [IIf(Length([items.ExciseLable])&gt;0m,nl + &quot;Акцизна марка: &quot; + [items.ExciseLable], &quot;&quot;)]" Font="Arial, 7pt"/>
      <LineObject Name="Line1" Left="18.9" Width="182.95" Border.Style="Dash" Diagonal="true"/>
      <TableObject Name="Table1" Left="18.14" Top="18.9" Width="182.94" Height="9.45">
        <TableColumn Name="Column4" Width="91.47"/>
        <TableColumn Name="Column5" Width="91.47"/>
        <TableRow Name="Row5" Height="9.45" AutoSize="true">
          <TableCell Name="Cell22" Text="[FormatNumber([items.Amount],3)] х [FormatNumber([items.Price],2)] [IIf(Length([OrgName])&gt;0m,IIf([items.Discount]&gt;0,nl + &quot;Знижка &quot; + FormatNumber([items.Discount],2),&quot;&quot;),IIf([items.Discount]&gt;0,nl + &quot;Знижка &quot; + FormatNumber([items.Price]*[items.Amount]-[items.Cost],2),&quot;&quot;))]" HorzAlign="Right" Font="Arial, 7pt"/>
          <TableCell Name="Cell23" Text="[IIf([items.Discount]&gt;0,nl, &quot;&quot;)] [IIf(Length([OrgName])&gt;0m,FormatNumber([items.Cost]-[items.Discount],2),FormatNumber([items.Cost],2))] [items.Letters]" HorzAlign="Right" Font="Arial, 7pt, style=Bold"/>
        </TableRow>
      </TableObject>
    </DataBand>
    <DataBand Name="Data6" Top="53.9" Width="219.24" Height="13.23" CanGrow="true" CanShrink="true" KeepTogether="true" KeepDetail="true">
      <TableObject Name="Table2" Left="18.14" Top="3.78" Width="182.94" Height="9.45" GrowToBottom="true" CanBreak="false" ManualBuildAutoSpans="false">
        <TableColumn Name="Column6" Width="91.47"/>
        <TableColumn Name="Column7" Width="91.47"/>
        <TableRow Name="Row6" Height="9.45" AutoSize="true">
          <TableCell Name="Cell24" Text="СУМА [IIf(ToDecimal([RoundSum])==0m,&quot;&quot;,nl + &quot;Заокруглення&quot;)]" HideZeros="true" AutoShrink="FontSize" Font="Arial, 9pt, style=Bold"/>
          <TableCell Name="Cell25" Text="[IIf(Length([OrgName])&gt;0m,FormatNumber([NoRoundSum],2) + &quot; ГРН&quot;,FormatNumber([TotalSum],2) + &quot; ГРН&quot;)] [IIf([RoundSum]==0m,&quot;&quot;,nl + [RoundSum] + &quot; грн&quot;)]" AutoShrink="FontSize" HorzAlign="Right" Font="Arial, 8pt, style=Bold"/>
        </TableRow>
      </TableObject>
      <LineObject Name="Line2" Left="18.14" Width="182.95" Border.Style="Dash" Diagonal="true"/>
    </DataBand>
    <DataBand Name="Data2" Top="69.51" Width="219.24" Height="9.45" CanGrow="true" CanShrink="true" DataSource="taxes" KeepTogether="true" KeepDetail="true">
      <TableObject Name="Table3" Left="18.14" Width="182.94" Height="9.45" CanBreak="false" ManualBuildAutoSpans="false">
        <TableColumn Name="Column8" Width="91.47"/>
        <TableColumn Name="Column9" Width="91.47"/>
        <TableRow Name="Row7" Height="9.45" AutoSize="true">
          <TableCell Name="Cell26" Text="[IIf([taxes.TaxPrc]==0,[taxes.Letter] + &quot; - БЕЗ ПДВ&quot;,[taxes.Name] + &quot; &quot; + [taxes.Letter] + &quot; = &quot; + [taxes.TaxPrc] +&quot; %&quot;)]" HideZeros="true" Font="Arial, 7pt"/>
          <TableCell Name="Cell27" Text="[IIf([taxes.TaxPrc]==0,&quot;&quot;,[taxes.TaxSum])]" HorzAlign="Right" Font="Arial, 7pt"/>
        </TableRow>
      </TableObject>
    </DataBand>
    <DataBand Name="Data3" Top="81.34" Width="219.24" Height="9.45" CanGrow="true" CanShrink="true" KeepTogether="true" KeepDetail="true">
      <TableObject Name="Table5" Left="18.14" Width="182.94" Height="9.45" CanBreak="false" ManualBuildAutoSpans="false">
        <TableColumn Name="Column12" Width="91.47"/>
        <TableColumn Name="Column13" Width="91.47"/>
        <TableRow Name="Row9" Height="9.45" AutoSize="true">
          <TableCell Name="Cell30" Text="[IIf([excises.ExciseSum]&gt;0,[excises.Name] + &quot; &quot; + [excises.Letter] + &quot; = &quot; + [excises.ExcisePrc] +&quot; %&quot;,&quot;&quot;)]" HideZeros="true" Font="Arial, 7pt"/>
          <TableCell Name="Cell31" Text="[IIf([excises.ExciseSum]&gt;0,[excises.ExciseSum],&quot;&quot;)]" HorzAlign="Right" Font="Arial, 7pt"/>
        </TableRow>
      </TableObject>
    </DataBand>
    <DataBand Name="Data7" Top="93.17" Width="219.24" Height="18.9" CanGrow="true" CanShrink="true" KeepTogether="true" KeepDetail="true">
      <TableObject Name="Table6" Left="18.14" Top="3.78" Width="182.94" Height="9.45" CanBreak="false" ManualBuildAutoSpans="false">
        <TableColumn Name="Column14" Width="91.47"/>
        <TableColumn Name="Column15" Width="91.47"/>
        <TableRow Name="Row10" Height="9.45" AutoSize="true">
          <TableCell Name="Cell32" Text="[IIf(ToDecimal([TotalDiscount])==0m,&quot;ДО СПЛАТИ&quot;,&quot;ЗНИЖКА&quot; + nl + &quot;ДО СПЛАТИ&quot;)]" HideZeros="true" Font="Arial, 10pt, style=Bold"/>
          <TableCell Name="Cell33" Text="[IIf(ToDecimal([TotalDiscount])==0m,FormatNumber([TotalSum],2) + &quot; грн&quot;, IIf(Length([OrgName])&gt;0m,FormatNumber([TotalDiscount],2) + &quot; грн&quot; + nl + FormatNumber([TotalSum],2) + &quot; грн&quot;, FormatNumber([TotalDiscount],2) + &quot; %&quot; + nl + FormatNumber([TotalSum],2) + &quot; грн&quot;))]" HorzAlign="Right" Font="Arial, 10pt, style=Bold"/>
        </TableRow>
      </TableObject>
      <LineObject Name="Line7" Left="18.14" Top="1.89" Width="182.95" Border.Style="Dash" Diagonal="true"/>
      <LineObject Name="Line8" Left="18.14" Top="14.36" Width="182.95" Border.Style="Dash" Diagonal="true"/>
    </DataBand>
    <DataBand Name="Data4" Top="114.46" Width="219.24" Height="10.58" CanGrow="true" CanShrink="true" DataSource="payments" KeepTogether="true" KeepDetail="true">
      <TableObject Name="Table4" Left="18.14" Top="1.13" Width="182.94" Height="9.45" CanBreak="false" ManualBuildAutoSpans="false">
        <TableColumn Name="Column10" Width="91.47"/>
        <TableColumn Name="Column11" Width="91.47"/>
        <TableRow Name="Row8" Height="9.45" AutoSize="true">
          <TableCell Name="Cell28" Text="[IIf(Length([OrgName])&gt;0m,IIf([payments.PayFormCd]==0,&quot;ГОТІВКА&quot;  + nl + &quot;РЕШТА&quot;,IIf([payments.PayFormCd]&lt;99999,&quot;БЕЗГОТІВКОВА&quot; + nl + [payments.PaymentName],&quot;ІНШЕ&quot; + nl + [payments.PaymentName])), [payments.PaymentName])]" HideZeros="true" Font="Arial, 7pt"/>
          <TableCell Name="Cell29" Text="[IIf(Length([OrgName])&gt;0m,IIf([payments.PayFormCd]==0,FormatNumber([payments.Sum]+[payments.Remains],2) + &quot; грн&quot; + nl + FormatNumber([payments.Remains],2) + &quot; грн&quot;, FormatNumber([payments.Sum],2) + &quot; грн&quot;),IIf([payments.PaymentName]==&quot;Готівкою&quot;,FormatNumber([payments.Sum],2) + &quot; грн&quot;,FormatNumber([payments.Sum],2) + &quot; грн&quot;))]" HorzAlign="Right" Font="Arial, 7pt"/>
        </TableRow>
      </TableObject>
    </DataBand>
    <DataBand Name="Data5" Top="127.42" Width="219.24" Height="9.45" CanGrow="true" CanShrink="true" DataSource="payments" KeepTogether="true" KeepDetail="true">
      <TextObject Name="Text1" Left="18.9" Width="182.95" Height="9.45" CanGrow="true" CanShrink="true" Text="[IIf(Length([payments.PosTransactionNumber])&gt;0m,IIf([CheckType]==0,&quot;Вид операції: Оплата&quot;,&quot;Вид операції: Повернення&quot;) + nl + &quot;Платіжна система: &quot; + [payments.PaymentSystem] + nl + &quot;Банк: &quot; + [payments.BankId] + nl + &quot;Термінал: &quot; + [payments.TerminalId] + nl + &quot;ЕПЗ: &quot; + [payments.CardNumber] + nl + &quot;RRN: &quot; + [payments.PosTransactionNumber] + nl + &quot;Код авторизації: &quot; + [payments.AuthorizationId] + nl + &quot;Комісія еквайра: &quot; + [payments.Commission], &quot;&quot;)]" Font="Arial, 7pt"/>
    </DataBand>
    <ReportSummaryBand Name="ReportSummary1" Top="139.25" Width="219.24" Height="219.24" CanGrow="true" CanShrink="true" CanBreak="true">
      <BarcodeObject Name="Barcode1" Left="50.25" Top="8.79" Width="124.74" Height="124.74" CanShrink="true" AutoSize="false" Text="[IIf(Length([QrLink])&gt;0m,[QrLink],&quot;https://cabinet.tax.gov.ua/cashregs/check?id=&quot;)]" ShowText="false" AllowExpressions="true" Barcode="QR Code" Barcode.ErrorCorrection="L" Barcode.Encoding="UTF8" Barcode.QuietZone="true"/>
      <TextObject Name="Text25" Left="90.72" Top="147.65" Width="111.51" Height="7.56" CanGrow="true" Text="[OrderDate]&#13;&#10;Режим роботи: [IIf(Length([OrgName])&gt;0m,IIf([Offline],&quot;Офлайн&quot;,&quot;Онлайн&quot;), &quot;Демо&quot;)] [IIf(Length([OrgName])&gt;0m,IIf([CheckType]==0,nl + &quot;ФІСКАЛЬНИЙ ЧЕК&quot; + nl + &quot;ФН ПРРО &quot; + [PrroFiscalNumber], nl + &quot;ВИДАТКОВИЙ ЧЕК&quot; + nl + &quot;ФН ПРРО &quot; + [PrroFiscalNumber]),nl + &quot;СЛУЖБОВИЙ ЧЕК&quot;)]&#13;&#10;[IIf([CheckType]==0,&quot;Дякуємо за покупку!&quot;, &quot;Заходьте ще!&quot;)]&#13;&#10;" HorzAlign="Center" Font="Arial, 6.5pt, style=Bold"/>
      <TextObject Name="Text33" Left="17.01" Top="6.18" Width="189" Height="9.45" CanGrow="true" CanShrink="true" Text="[IIf(Length([OrgName])&gt;0m,IIf([CheckType]==0,&quot;Фіскальний Чек № &quot; + [OrderTaxNum],&quot;Видатковий Чек № &quot; + [OrderTaxNum]), &quot;Чек № &quot; + [DocumentNumber])]" HorzAlign="Center" Font="Arial, 6.5pt, style=Bold"/>
      <PictureObject Name="Picture1" Left="18.9" Top="147.78" Width="75.6" Height="56.7" Image=""/>
      <LineObject Name="Line6" Left="18.14" Top="3.78" Width="182.95" Border.Style="Dash" Diagonal="true"/>
      <TextObject Name="Text34" Left="18.33" Top="129.19" Width="182.95" Height="17.01" CanGrow="true" CanShrink="true" Text="[IIf(Length([ControlNumber])&gt;0m,&quot;Контрольне число: &quot; + [ControlNumber],&quot;&quot;)]" Font="Arial, 6pt"/>
      <TextObject Name="Text35" Left="18.14" Top="158.76" Width="182.95" Height="7.56" CanGrow="true" CanShrink="true" GrowToBottom="true" Text="[IIf([RoundSum]&gt;Math.Abs([DiscountOnSale]),IIf([CheckType]==0, &quot;Списано балів: &quot; + FormatNumber([RoundSum]-[DiscountOnSale],2), &quot;Повернуто балів: &quot; + FormatNumber([RoundSum]-[DiscountOnSale],2)),&quot;&quot;)]&#13;&#10;[IIf([ClientBonusesSum]&gt;0,&quot;Нараховано балів: &quot; +  FormatNumber([ReceiveBonuses],2) + nl + &quot;Всього балів: &quot; + FormatNumber([ClientBonusesSum],2),&quot;&quot;)]&#13;&#10;[IIf([ClientCreditSum]&gt;0,&quot;Борг: &quot; + FormatNumber([ClientCreditSum],2),&quot;&quot;)]" Font="Arial, 6.5pt, style=Bold"/>
    </ReportSummaryBand>
  </ReportPage>
</Report>
